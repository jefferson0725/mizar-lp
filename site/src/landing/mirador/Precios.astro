---
const WA_URL = "https://wa.me/573102941376?text=Hola%2C%20me%20interesan%20los%20lotes%20de%20Mirador%20de%20la%20Monta%C3%B1a%2C%20mi%20nombre%20es%20";

const tarjetas = [
  {
    titulo: "Sin bancos, sin codeudores",
    descripcion: "Financiamos directo contigo. Sin filtros de banco ni papeleo interminable.",
    iconPath: `<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  },
  {
    titulo: "Cuotas a tu medida",
    descripcion: "Un plan de pagos pensado para que estrenes tierra sin ahogarte.",
    iconPath: `<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>`,
  },
];

const checklist = [
  "Bono especial de $5.000.000",
  "Planos arquitectónicos incluidos",
  "Lote listo para construir",
];
---

<section id="precios" class="py-20 px-6 bg-navy">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="reveal font-serif text-blanco text-3xl sm:text-4xl md:text-5xl mb-6 leading-tight">
      Financiación directa, sin bancos.
    </h2>

    <div class="reveal inline-block bg-white/10 border border-white/15 rounded-2xl px-8 py-5 mb-10">
      <p class="text-rojo-light font-bold text-3xl md:text-4xl">Lotes desde $75.000.000</p>
      <p class="text-white/75 text-base mt-1">Separa el tuyo con solo $3.000.000</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
      {tarjetas.map((t, i) => (
        <div
          class="reveal bg-white/10 border border-white/10 rounded-2xl p-8 text-left"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <svg class="w-8 h-8 text-rojo-light mb-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" set:html={t.iconPath}></svg>
          <h3 class="text-blanco font-bold text-xl mb-2">{t.titulo}</h3>
          <p class="text-white/70 text-base leading-relaxed">{t.descripcion}</p>
        </div>
      ))}
    </div>

    <div class="space-y-3 mb-10">
      {checklist.map((item) => (
        <div class="flex items-start gap-3 text-left max-w-xl mx-auto">
          <svg class="w-5 h-5 text-rojo-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <p class="text-blanco text-base">{item}</p>
        </div>
      ))}
    </div>

    <a
      href={WA_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-rojo text-white font-bold px-10 py-4 rounded-lg text-lg hover:bg-rojo-dark transition-colors duration-300 shadow-hover"
      data-event="whatsapp-click"
    >
      Quiero saber más
    </a>
  </div>
</section>
