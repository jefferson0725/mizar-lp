---
const INSTAGRAM_URL = "https://www.instagram.com/mizar.col/?utm_source=ig_embed&ig_rid=eabde098-a6fb-4cce-8c10-5502c784701b";
---

<section id="video-testimonios" class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal font-serif text-navy text-3xl sm:text-4xl md:text-5xl text-center mb-12 leading-tight">
      Hemos ayudado a cientos de personas a comprar su apartamento de la
      forma más sencilla.
    </h2>

    <div class="reveal flex justify-center mb-14">
      <div class="w-full max-w-sm">
        <div class="relative">
          <video
            id="testimonios-video"
            src="/videos/testimonios.mp4"
            poster="/videos/posters/testimonios.jpg"
            autoplay
            muted
            loop
            playsinline
            preload="none"
            class="w-full rounded-xl"
            style="display: block"
          ></video>
          <button
            id="mute-btn"
            class="absolute bottom-4 right-4 bg-black bg-opacity-60 hover:bg-opacity-80 text-white p-2.5 rounded-full transition-all"
            title="Activar audio"
            aria-label="Activar audio"
          >
            <!-- VolumeX icon (muted state — shown by default) -->
            <svg id="icon-muted" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"/>
              <line x1="22" x2="16" y1="9" y2="15"/>
              <line x1="16" x2="22" y1="9" y2="15"/>
            </svg>
            <!-- Volume2 icon (unmuted state — hidden by default) -->
            <svg id="icon-unmuted" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z"/>
              <path d="M16 9a5 5 0 0 1 0 6"/>
              <path d="M19.364 18.364a9 9 0 0 0 0-12.728"/>
            </svg>
          </button>
        </div>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-full mt-2 py-3 text-blue-400 font-medium hover:text-blue-300 transition-colors"
        >
          Ver más en Instagram
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('testimonios-video') as HTMLVideoElement | null;
  const btn = document.getElementById('mute-btn');
  const iconMuted = document.getElementById('icon-muted');
  const iconUnmuted = document.getElementById('icon-unmuted');

  btn?.addEventListener('click', () => {
    if (!video) return;
    video.muted = !video.muted;
    iconMuted?.classList.toggle('hidden', !video.muted);
    iconUnmuted?.classList.toggle('hidden', video.muted);
    if (btn) {
      btn.title = video.muted ? 'Activar audio' : 'Desactivar audio';
      btn.setAttribute('aria-label', video.muted ? 'Activar audio' : 'Desactivar audio');
    }
  });
</script>
