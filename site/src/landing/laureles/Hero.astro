---
// hero-fachada.webp ya está en public/assets como webp optimizado — se referencia
// directamente. No se usa astro:assets porque no es un PNG local sin procesar.
---

<section class="relative min-h-screen flex flex-col items-center justify-center bg-navy-dark overflow-hidden">
  <!-- Fondo: paneo HORIZONTAL en bucle continuo (tipo video), independiente del scroll. -->
  <div
    class="lc-hero-bg absolute inset-y-0 left-0 w-[135%] bg-cover bg-center will-change-transform"
    style="background-image: url('/assets/hero-fachada.webp')"
    aria-hidden="true"
  ></div>
  <!-- Overlay navy para legibilidad -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/80 via-navy-dark/65 to-navy-dark/85"></div>

  <!-- Logo Mizar -->
  <img
    src="/assets/logo-mizar.webp"
    alt="Mizar · Diseño y Construcción"
    class="lc-hero-logo relative z-10 h-9 md:h-11 w-auto mb-10"
  />

  <div class="lc-hero-content relative z-10 text-center px-6 max-w-3xl mx-auto">
    <p class="text-rojo-light font-semibold tracking-widest uppercase text-xs md:text-sm mb-5">
      Laureles Campestre
    </p>
    <h1 class="font-serif font-black text-white text-4xl sm:text-5xl md:text-6xl leading-[1.08] mb-6">
      Tu apartamento propio en Girón,
      <span class="text-rojo-light">sin bancos y a cuotas.</span>
    </h1>
    <p class="text-white/85 text-lg md:text-xl mb-10 font-light max-w-2xl mx-auto">
      Apartamentos sobre planos a 150 metros del futuro anillo vial, en la
      zona de mayor crecimiento de Girón.
    </p>
    <a
      href="#proposicion-valor"
      class="inline-block bg-rojo text-white font-bold px-8 py-4 rounded-lg text-lg hover:bg-rojo-dark transition-colors duration-300 shadow-hover"
    >
      Quiero conocer mis opciones
    </a>
    <p class="text-white/65 text-sm mt-6 tracking-widest uppercase">
      Entregas 2027 · 2028
    </p>
  </div>

  <!-- Indicador de scroll -->
  <div class="lc-hero-arrow absolute bottom-8 left-1/2 z-10 text-white/60" aria-hidden="true">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
