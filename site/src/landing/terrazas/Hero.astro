---
// Hero — Terrazas de la Cantera
// Reutiliza las clases CSS lc-hero-* definidas en landing/index.css.
// Las animaciones (pan-bg, fade-down, fade-up, bounce) son idénticas a laureles.
---

<section class="relative min-h-screen flex flex-col items-center justify-center bg-navy-dark overflow-hidden">
  <!-- Fondo: paneo horizontal en bucle continuo -->
  <div
    class="lc-hero-bg absolute inset-y-0 left-0 w-[135%] bg-cover bg-center will-change-transform"
    style="background-image: url('/assets/terrazas-fachada.webp')"
    aria-hidden="true"
  ></div>
  <!-- Overlay navy para legibilidad -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-dark/85 via-navy-dark/70 to-navy-dark/88"></div>

  <!-- Logo Terrazas -->
  <img
    src="/assets/logo-terrazas.webp"
    alt="Terrazas de la Cantera"
    class="lc-hero-logo relative z-10 h-20 md:h-28 w-auto mb-8"
  />

  <div class="lc-hero-content relative z-10 text-center px-6 max-w-3xl mx-auto">
    <h1 class="font-serif font-black text-white text-4xl sm:text-5xl md:text-6xl leading-[1.08] mb-6">
      Tu apartamento propio en Piedecuesta,
      <span class="text-rojo-light">sin bancos y sin viajar.</span>
    </h1>
    <p class="text-white/85 text-lg md:text-xl mb-10 font-light max-w-2xl mx-auto">
      Apartamentos sobre planos en el centro de Piedecuesta. Pago a cuotas
      directo con Mizar, desde donde estés.
    </p>
    <a
      href="#intro"
      class="inline-block bg-rojo text-navy font-bold px-8 py-4 rounded-lg text-lg hover:bg-rojo-dark hover:text-navy transition-colors duration-300 shadow-hover"
      data-event="hero-cta-click"
    >
      Quiero conocer mis opciones
    </a>
    <p class="text-white/65 text-sm mt-6 tracking-widest uppercase">
      Entrega proyectada · Diciembre 2027
    </p>
  </div>

  <!-- Indicador de scroll -->
  <div class="lc-hero-arrow absolute bottom-8 left-1/2 z-10 text-white/60" aria-hidden="true">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
