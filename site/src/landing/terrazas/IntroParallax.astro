---
import Hero from './Hero.astro';
---

<Hero />

<!-- ===================================================================
    SECCIÓN GANCHO — Terrazas de la Cantera
    Móvil  : texto (navy) → video del edificio
    Desktop: dos columnas — video izquierda | texto derecha
=================================================================== -->
<section id="intro" class="bg-navy overflow-hidden">
  <div class="flex flex-col md:grid md:grid-cols-2 md:min-h-[580px]">
    <!-- Columna texto (derecha en desktop, primera en móvil) -->
    <div class="reveal flex flex-col justify-center py-20 px-8 md:py-28 md:px-14 lg:px-20 md:order-2">
      <p class="text-rojo-light font-semibold tracking-widest uppercase text-xs md:text-sm mb-6">
        Hablemos claro
      </p>
      <h2 class="font-serif text-white text-3xl sm:text-4xl md:text-5xl leading-[1.15] mb-8">
        Llevas años trabajando duro lejos de casa.
        <span class="text-white/55">
          ¿Qué tienes hoy en Colombia que asegure tu retiro?
        </span>
      </h2>
      <p class="text-white text-xl md:text-2xl font-light max-w-xl">
        Cada vez más personas están eligiendo Piedecuesta para vivir. Tú
        puedes ser dueño en el mejor punto, sin importar dónde estés hoy.
      </p>
    </div>

    <!-- Columna video (izquierda en desktop, segunda en móvil) -->
    <div class="reveal relative md:order-1 flex items-center justify-center mb-8 md:mb-0 px-4 md:px-0 py-8 md:py-0">
      <div class="w-full aspect-[10/12] rounded-3xl overflow-hidden shadow-dark border border-white/10">
        <video
          class="w-full h-full object-cover block"
          src="/assets/timeline-edificio.mp4"
          poster="/assets/render-edificio.webp"
          autoplay
          loop
          muted
          playsinline
          preload="none"
        ></video>
      </div>
    </div>
  </div>
</section>
