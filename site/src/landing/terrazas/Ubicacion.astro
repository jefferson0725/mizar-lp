---
const MAPS_URL =
  "https://www.google.com/maps/place/Terrazas+de+la+Cantera/data=!4m2!3m1!1s0x0:0x3cf669ce4908575f?sa=X&ved=1t:2428&ictx=111";
const MAPS_EMBED_URL =
  "https://maps.google.com/maps?q=Terrazas+de+la+Cantera+Piedecuesta&z=16&output=embed";

const puntos = [
  {
    texto: "A 4 cuadras del Parque Principal y la Plaza de Mercado.",
    icon: `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>`,
  },
  {
    texto: "Frente al Cerro de La Cantera, uno de los pulmones verdes y puntos turísticos del sector.",
    icon: `<path d="M10 10v.2A3 3 0 0 1 8.9 16H5a3 3 0 0 1-1-5.8V10a3 3 0 0 1 6 0Z"/><path d="M7 16v6"/><path d="M13 19v3"/><path d="M12 19h8.3a1 1 0 0 0 .7-1.7L18 14h.3a1 1 0 0 0 .7-1.7L16 9h.2a1 1 0 0 0 .8-1.7L13 3l-1.4 1.5"/>`,
  },
  {
    texto: "Acceso directo a transporte público y vías principales.",
    icon: `<path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/><path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/><circle cx="7" cy="18" r="2"/><path d="M9 18h5"/><circle cx="16" cy="18" r="2"/>`,
  },
];

const features = [
  {
    texto: "Torre de 5 pisos",
    icon: `<path d="M10 12h4"/><path d="M10 8h4"/><path d="M14 21v-3a2 2 0 0 0-4 0v3"/><path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2"/><path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/>`,
  },
  {
    texto: "Parqueadero en sótano",
    icon: `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>`,
  },
  {
    texto: "Full acabados",
    icon: `<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>`,
  },
];
---

<section class="py-20 px-6 bg-gris-claro">
  <div class="max-w-5xl mx-auto">
    <h2 class="reveal font-serif text-navy text-3xl sm:text-4xl md:text-5xl text-center mb-12 leading-tight">
      Estás comprando en el mejor punto de Piedecuesta.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
      {puntos.map((punto, i) => (
        <div
          class="reveal text-center p-6 rounded-xl bg-white border border-gris-claro shadow-card hover:shadow-hover transition-shadow"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <svg class="w-10 h-10 text-navy mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" set:html={punto.icon}></svg>
          <p class="text-gris-oscuro text-base leading-relaxed">{punto.texto}</p>
        </div>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      {features.map((f, i) => (
        <div
          class="reveal inline-flex items-center gap-2 bg-navy text-white rounded-full px-5 py-2.5 text-sm font-semibold"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <svg class="w-4 h-4 text-rojo-light" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" set:html={f.icon}></svg>
          {f.texto}
        </div>
      ))}
    </div>

    <p class="reveal text-gris-oscuro text-center text-lg max-w-3xl mx-auto mb-12">
      El centro de Piedecuesta concentra todo lo que necesitas a pie, y el Cerro de La Cantera le da naturaleza y plusvalía a la zona.
    </p>

    <div class="reveal w-full rounded-xl overflow-hidden shadow-card mb-6 border border-gris-claro">
      <iframe
        src={MAPS_EMBED_URL}
        title="Ubicación de Terrazas de la Cantera en Piedecuesta"
        class="w-full h-[340px] md:h-[420px] border-0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <div class="reveal flex justify-center mb-12">
      <a
        href={MAPS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-rojo text-navy font-semibold px-6 py-3 rounded-lg hover:bg-rojo-dark hover:text-navy transition-colors duration-300 shadow-lg"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
          <polygon points="3 11 22 2 13 21 11 13 3 11"/>
        </svg>
        Cómo llegar
      </a>
    </div>

    <p class="text-navy font-bold text-center text-xl md:text-2xl">
      Más conexión, más naturaleza, más ciudad.
      <span class="text-rojo-dark">Un apartamento que gana valor todos los días.</span>
    </p>
  </div>
</section>
