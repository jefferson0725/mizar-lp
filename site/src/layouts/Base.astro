---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { getWhatsAppConfig } from '../data/whatsapp';
import Analytics from '../components/Analytics.astro';
import { orgSchema } from '../data/schema';
import archivoLatinWghtNormal from '@fontsource-variable/archivo/files/archivo-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  /** Ruta canónica, ej. "/nosotros" */
  path?: string;
  ogImage?: string;
  /** JSON-LD adicional de la página (Organization ya va global) */
  schema?: object | object[];
  /** Header flotante transparente sobre el hero (páginas con hero oscuro full-bleed) */
  headerTransparent?: boolean;
  /** Dirección que muestra el footer (sobreescribe el default de Bucaramanga) */
  footerDireccion?: string;
  /** URL del recurso LCP para preload (hero image) */
  preloadImage?: string;
}

const {
  title,
  description,
  path = '/',
  ogImage = '/og-default.jpg',
  schema,
  headerTransparent = false,
  footerDireccion,
  preloadImage,
} = Astro.props;
const wa = getWhatsAppConfig(path);
const site = Astro.site ?? new URL('https://mizar.com.co');
const canonical = new URL(path, site).href;
const usesGoogleMapsEmbed =
  path === '/contacto' ||
  path === '/lotes-cucuta' ||
  path === '/apartamentos-piedecuesta' ||
  path === '/apartamentos-giron';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {preloadImage && <link rel="preload" as="image" fetchpriority="high" href={preloadImage} />}
    <link
      rel="preload"
      href={archivoLatinWghtNormal}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://maps.app.goo.gl" />
    <link rel="dns-prefetch" href="https://wa.me" />
    <link rel="dns-prefetch" href="https://mizar.sixteam.pro" />
    {usesGoogleMapsEmbed && <link rel="preconnect" href="https://www.google.com" crossorigin />}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Grupo Mizar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, site).href} />
    <meta property="og:locale" content="es_CO" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <Analytics />
  </head>
  <body>
    <Header transparent={headerTransparent} />
    <main class:list={[!headerTransparent && 'pt-16']}>
      <slot />
    </main>
    <Footer direccion={footerDireccion} />
    <WhatsAppFloat phone={wa.phone} message={wa.message} />
  </body>
</html>
