---
import { getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import FaqAccordion from '../components/proyectos/FaqAccordion.astro';
import GalleryCarousel from '../components/GalleryCarousel.astro';
import { WHATSAPP_MILOTE } from '../data/proyectos';
import renderLotes from '../assets/proyectos/lotes-cucuta.png';
import imagen1Raw from '../assets/proyectos/miravista-imagen1.png';
import galeriaRaw1 from '../assets/proyectos/miravista-g1.png';
import galeriaRaw2 from '../assets/proyectos/miravista-g2.png';
import galeriaRaw3 from '../assets/proyectos/miravista-g3.png';
import galeriaRaw4 from '../assets/proyectos/miravista-g4.png';
import galeriaRaw5 from '../assets/proyectos/miravista-g5.png';

const wa = (msg: string) =>
  `https://wa.me/${WHATSAPP_MILOTE}?text=${encodeURIComponent(msg)}`;

const heroBg = (await getImage({ src: renderLotes, width: 1800, format: 'webp' })).src;
const renderMid = (await getImage({ src: renderLotes, width: 1200, format: 'webp' })).src;
const imagen1 = (await getImage({ src: imagen1Raw, width: 900, format: 'webp' })).src;

const galeria = await Promise.all(
  [galeriaRaw1, galeriaRaw2, galeriaRaw3, galeriaRaw4, galeriaRaw5].map((img) =>
    getImage({ src: img, width: 900, format: 'webp' }).then((r) => r.src),
  ),
);

const incluye = [
  'Lote de 7x10 o 7x16 metros',
  'Escritura independiente: 100% legal, a tu nombre',
  'Pago a cuotas sin intereses, sin bancos y sin intermediarios',
  'Servicios públicos y vías garantizados: agua, luz, alcantarillado, pavimentación, andenes',
  'Zonas verdes',
  'Diseño arquitectónico personalizado a la medida, sin costo adicional',
  'El respaldo del Grupo Mizar: +20 años y +100 obras entregadas',
];

const resumen = [
  { label: 'Lote urbano de 7x10 o 7x16 metros', valor: 'Tuyo' },
  { label: 'Escritura independiente', valor: 'A tu nombre' },
  { label: 'Bancos, intereses y codeudores', valor: 'Cero' },
  { label: 'Diseño arquitectónico personalizado', valor: 'Incluido' },
  { label: 'Servicios públicos y vías', valor: 'Garantizados' },
];

const ubicacion = [
  'Junto al anillo vial occidental de Cúcuta',
  'A 100 metros de la futura Universidad Simón Bolívar',
  'En San Cayetano, a minutos del centro de Cúcuta',
  'Zona de crecimiento con valorización por delante',
];

const pasos = [
  { n: '1', t: 'Separas tu lote', d: 'Eliges el tamaño (7x10 o 7x16) y lo apartas con nuestro equipo, en persona o por videollamada.' },
  { n: '2', t: 'Pagas cuotas fijas, sin intereses', d: 'Acordamos un plan de pagos directo con nosotros, según tu capacidad real. Sin bancos ni estudio de crédito.' },
  { n: '3', t: 'Escrituras a tu nombre', d: 'Recibes tu escritura independiente: tierra 100% legal y legalmente tuya, lista para construir.' },
];

const faq = [
  {
    q: '¿Tengo que pasar por un banco o tener historial crediticio?',
    a: 'No. Pagas directamente a cuotas, sin intereses y sin bancos. No hay estudio de crédito ni hipoteca: por eso es accesible incluso si nunca has comprado tierra antes.',
  },
  {
    q: '¿Puedo comprar si vivo en el exterior?',
    a: 'Sí. Muchos de nuestros propietarios viven fuera de Colombia. Te acompañamos en todo el proceso y puedes avanzar desde donde estés.',
  },
  {
    q: '¿Qué puedo construir en el lote?',
    a: 'Lo que decidas: casa, local comercial o un edificio que te genere ingresos. El diseño arquitectónico se personaliza a la medida de lo que quieras hacer.',
  },
  {
    q: '¿En qué se diferencia Mi Lote de otras urbanizadoras?',
    a: 'En tres cosas que no se improvisan: escrituración independiente, diseño arquitectónico personalizado, y el respaldo de 20 años del Grupo Mizar. No solo te vendemos un lote, te entregamos algo legalmente tuyo y listo para construir.',
  },
  {
    q: '¿El proyecto es legal y está en regla?',
    a: 'Sí. Miravista es suelo urbano con escrituración independiente y servicios garantizados. Toda la documentación está en regla y la revisas antes de decidir.',
  },
  {
    q: '¿Y si en algún momento no puedo seguir pagando?',
    a: 'Conversamos contigo. No es un proceso bancario frío: trabajamos con procesos humanos y claros, pensados para acompañarte, no para presionarte.',
  },
  {
    q: '¿Dónde queda y cómo lo conozco?',
    a: 'En San Cayetano, Cúcuta, a pocos minutos del anillo vial occidental. La mejor forma de conocerlo es agendar una visita o una llamada con nuestro equipo.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schema = [
  faqSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://mizar.com.co/' },
      { '@type': 'ListItem', position: 2, name: 'Mi Lote en Cúcuta', item: 'https://mizar.com.co/lotes-cucuta' },
    ],
  },
];
---

<Base
  title="Mi Lote — Tu lote propio en Cúcuta, a cuotas y sin bancos"
  description="Lotes urbanos de 7×10 y 7×16 en San Cayetano, Cúcuta, a 100 m de la futura Universidad Simón Bolívar, con escritura independiente y cuotas sin bancos."
  path="/lotes-cucuta"
  schema={schema}
>
  <!-- HERO -->
  <section class="relative flex min-h-[65vh] flex-col justify-start overflow-hidden bg-neutral-950 text-white">
    <img
      src={heroBg}
      alt="Render aéreo de la urbanización Miravista en San Cayetano, Cúcuta"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0" style="background:#000000a8;"></div>
    <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,0,0,0.8),transparent,rgba(0,0,0,0.3))"></div>

    <div class="container-site relative pt-20 pb-12 md:pt-32 md:pb-20">
      <p class="eyebrow text-gold">Mi Lote · San Cayetano, Cúcuta</p>
      <h1 class="display-xl mt-4 max-w-3xl text-4xl md:text-6xl">
        Tu lote propio, a cuotas, sin bancos
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/85">
        Llevas años trabajando duro, y no tienes nada a tu nombre. Hoy ese esfuerzo puede
        quedar en tierra propia, de forma segura.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={wa('Hola, vengo de la web de Mi Lote y quiero información de los lotes en San Cayetano.')} target="_blank" rel="noopener" class="btn-primary" data-event="whatsapp-click">
          Quiero mi lote
        </a>
        <a href="#incluye" class="btn-outline text-white">Ver qué incluye</a>
      </div>
    </div>
  </section>

  <!-- VIDEO + RESPALDO -->
  <section class="py-14 md:py-20">
    <div class="container-site grid gap-12 md:grid-cols-2 md:items-center">
      <!-- Respaldo -->
      <div>
        <p class="eyebrow text-teal">El respaldo</p>
        <h2 class="display-lg mt-3 text-3xl">Detrás de Mi Lote está Grupo Mizar</h2>
        <p class="mt-4 leading-relaxed text-ink/75">
          Más de 20 años construyendo en Colombia y más de 100 obras entregadas.
        </p>
        <a href="/nosotros" class="mt-5 inline-block font-bold text-mizar hover:underline">Conoce nuestra historia →</a>
        <div class="mt-8 grid grid-cols-2 gap-8">
          <div>
            <p class="stat-num text-5xl text-plum">20<span class="text-mizar">+</span></p>
            <p class="mt-1 text-sm font-semibold tracking-wider text-ink/60 uppercase">Años construyendo en Colombia</p>
          </div>
          <div>
            <p class="stat-num text-5xl text-plum">100<span class="text-mizar">+</span></p>
            <p class="mt-1 text-sm font-semibold tracking-wider text-ink/60 uppercase">Obras entregadas</p>
          </div>
          <p class="col-span-2 max-w-prose text-ink/75">
            Somos una empresa familiar de ingenieros santandereanos. Respondemos con nombre
            propio por cada obra que entregamos, desde parques públicos premiados hasta la
            urbanización más grande de San Cayetano.
          </p>
        </div>
      </div>

      <!-- Video -->
      <div class="mx-auto w-full max-w-sm">
        <div class="relative overflow-hidden rounded-2xl bg-plum-dark">
          <video
            id="video-recorrido"
            src="/videos/mi-lote-recorrido.mp4"
            class="block w-full object-cover" style="aspect-ratio:9/16"
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
          <button
            id="recorrido-audio-toggle"
            type="button"
            class="absolute right-4 bottom-4 flex h-12 w-12 items-center justify-center rounded-full bg-black/60 text-white"
            aria-label="Activar sonido"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M11 5 6 9H2v6h4l5 4V5ZM23 9l-6 6M17 9l6 6" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGEN + UBICACION + MAPA -->
  <section class="py-16 md:py-24">
    <div class="container-site">
      <div class="grid items-center gap-10 md:grid-cols-[6fr_6fr]">
        <img
          src={imagen1}
          alt="Vista de la urbanización Miravista en San Cayetano, Cúcuta"
          loading="lazy"
          class="w-full rounded-2xl"
        />
        <div>
          <p class="eyebrow text-teal">Ubicación</p>
          <h2 class="display-lg mt-3 text-3xl md:text-4xl">
            Junto al anillo vial occidental y a 100 metros de la futura Universidad Simón Bolívar
          </h2>
          <ul class="mt-7 space-y-4">
            {
              ubicacion.map((u) => (
                <li class="flex items-start gap-3">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#35565a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 1 1 16 0Z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                  <span class="font-medium">{u}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      <iframe
        src="https://www.google.com/maps?q=7.877946,-72.5468263&z=17&output=embed"
        title="Mapa de la urbanización Miravista en San Cayetano, Cúcuta"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="mt-10 h-72 w-full rounded-2xl border-0 md:h-96"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <!-- LO QUE INCLUYE -->
  <section class="bg-white py-16 md:py-24" id="incluye">
    <div class="container-site grid gap-12 md:grid-cols-[7fr_5fr]">
      <div>
        <p class="eyebrow text-teal">Sin letra pequeña</p>
        <h2 class="display-lg mt-3 text-3xl md:text-4xl">Lo que incluye tu lote</h2>
        <ul class="mt-8 space-y-4">
          {
            incluye.map((item) => (
              <li class="flex items-start gap-3 border-b border-ink/10 pb-4">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d9a441" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="font-medium">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="h-fit rounded-2xl bg-plum p-7 text-white md:sticky md:top-24">
        <p class="eyebrow text-gold">En resumen</p>
        <ul class="mt-5 divide-y divide-white/10">
          {
            resumen.map((r) => (
              <li class="flex items-baseline justify-between gap-4 py-3.5">
                <span class="text-sm text-white/80">{r.label}</span>
                <span class="shrink-0 font-extrabold text-gold">{r.valor}</span>
              </li>
            ))
          }
        </ul>
        <a href={wa('Hola, quiero saber precios y disponibilidad de los lotes en San Cayetano.')} target="_blank" rel="noopener" class="btn-primary mt-6 flex w-full justify-center" data-event="whatsapp-click">
          Pregunta precio y disponibilidad
        </a>
      </aside>
    </div>
  </section>

  <!-- GALERIA -->
  <section class="bg-white py-16 md:py-24">
    <div class="container-site">
      <p class="eyebrow text-teal">La urbanización</p>
      <h2 class="display-lg mt-3 max-w-xl text-3xl md:text-4xl">Así avanza Miravista</h2>
      <div class="relative mt-8" data-carousel-root>
        <div
          data-carousel-track
          class="flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {[
            { src: renderMid, alt: 'Render aéreo de la glorieta de entrada de Miravista' },
            { src: imagen1,   alt: 'Vista de la urbanización Miravista' },
            ...galeria.map((src, i) => ({ src, alt: `Avance de la urbanización Miravista ${i + 1}` })),
          ].map(({ src, alt }) => (
            <img
              src={src}
              alt={alt}
              loading="lazy"
              class="w-[85%] shrink-0 snap-start rounded-2xl object-cover sm:w-[55%] lg:w-[38%]"
              style="aspect-ratio:4/3"
            />
          ))}
        </div>
        <GalleryCarousel />
      </div>
      <div data-carousel-dots class="mt-5 flex items-center justify-center gap-2"></div>
    </div>
  </section>

  <!-- ENTRAR AHORA + EXTERIOR -->
  <section class="py-16 md:py-24">
    <div class="container-site grid gap-10 md:grid-cols-[7fr_5fr] md:items-center">
      <div>
        <p class="display-lg text-2xl text-plum md:text-3xl">Entrar ahora es entrar a tiempo.</p>
        <p class="mt-5 max-w-prose leading-relaxed text-ink/75">
          San Cayetano está creciendo. La futura Universidad Simón Bolívar queda a 100 metros de
          la urbanización. La tierra de hoy no va a costar lo mismo mañana.
        </p>
        <p class="mt-4 max-w-prose leading-relaxed text-ink/75">
          Y si vives fuera del país, puedes invertir desde donde estés: te acompañamos en cada
          paso del proceso.
        </p>
      </div>
      <a href={wa('Hola, vivo fuera de Colombia y quiero invertir en un lote de Mi Lote en Cúcuta.')} target="_blank" rel="noopener" class="btn-primary justify-self-start md:justify-self-end" data-event="whatsapp-click">
        Invierto desde el exterior
      </a>
    </div>
  </section>

  <!-- TESTIMONIOS EN VIDEO -->
  <section class="bg-white py-16 md:py-24">
    <div class="container-site grid items-center gap-10 md:grid-cols-[5fr_7fr]">
      <div>
        <p class="eyebrow text-teal">Testimonios</p>
        <h2 class="display-lg mt-3 text-3xl md:text-4xl">Ellos ya dieron el paso</h2>
        <p class="mt-4 max-w-prose leading-relaxed text-ink/75">
          Personas que trabajaron años sin tener nada a su nombre y hoy pagan su propiedad
          directo con la constructora. Dale play y escúchalos.
        </p>
      </div>
      <div class="mx-auto w-full max-w-xs">
        <div class="relative overflow-hidden rounded-2xl bg-plum-dark">
          <video
            id="video-testimonio"
            src="/videos/testimonios.mp4"
            class="block w-full object-cover" style="aspect-ratio:9/16"
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
          <button
            id="video-audio-toggle"
            type="button"
            class="absolute right-4 bottom-4 flex h-12 w-12 items-center justify-center rounded-full bg-black/60 text-white"
            aria-label="Activar sonido"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M11 5 6 9H2v6h4l5 4V5ZM23 9l-6 6M17 9l6 6" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- COMENTARIOS -->
  <section class="py-16 md:py-24">
    <div class="container-site">
      <p class="eyebrow text-teal">Comentarios</p>
      <h2 class="display-lg mt-3 max-w-xl text-3xl md:text-4xl">Lo que dicen quienes ya compraron</h2>
      <div class="relative mt-8" data-carousel-root>
        <div
          data-carousel-track
          class="flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          {
            [
              {
                quote: 'Compré mi lote desde Estados Unidos. Todo el proceso fue por videollamada y los documentos llegaron en regla.',
                autor: 'Inversionista, vive en EE. UU.',
              },
              {
                quote: 'Lo que me convenció fue que no hay letra pequeña: cuota fija, sin intereses, y la escritura queda a mi nombre.',
                autor: 'Comprador en San Cayetano',
              },
              {
                quote: 'Nunca había podido comprar nada porque estaba reportado. Aquí nadie me pidió puntaje de crédito.',
                autor: 'Comprador en Cúcuta',
              },
              {
                quote: 'Llevaba años pagando arriendo y pensando que sin crédito nunca iba a tener nada. Hoy tengo tierra propia.',
                autor: 'Propietaria, Norte de Santander',
              },
            ].map((c) => (
              <blockquote class="min-w-[85%] snap-start rounded-2xl border-l-2 border-gold bg-white p-6 sm:min-w-[45%] lg:min-w-[30%]">
                <p class="leading-relaxed text-ink/85">"{c.quote}"</p>
                <footer class="mt-4 text-sm font-bold text-teal">{c.autor}</footer>
              </blockquote>
            ))
          }
        </div>
        <GalleryCarousel />
      </div>
      <div data-carousel-dots class="mt-5 flex items-center justify-center gap-2"></div>
    </div>
  </section>

  <!-- PLAN DE PAGOS -->
  <section class="bg-plum py-16 text-white md:py-24">
    <div class="container-site">
      <div class="max-w-2xl">
        <p class="eyebrow text-gold">Así de simple</p>
        <h2 class="display-lg mt-3 text-3xl md:text-4xl">Tu plan de pagos, directo y sin bancos</h2>
      </div>
      <ol class="mt-12 grid gap-8 md:grid-cols-3">
        {
          pasos.map((p) => (
            <li class="border-t-2 border-gold pt-4">
              <span class="stat-num text-4xl text-gold/80">{p.n}</span>
              <h3 class="mt-2 font-bold">{p.t}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-white/70">{p.d}</p>
            </li>
          ))
        }
      </ol>
      <a href={wa('Hola, quiero conocer el plan de cuotas de los lotes de San Cayetano.')} target="_blank" rel="noopener" class="btn-primary mt-10" data-event="whatsapp-click">
        Conocer mi plan de cuotas
      </a>
    </div>
  </section>

  <!-- OFICINAS -->
  <section class="py-14 md:py-20">
    <div class="container-site flex flex-wrap items-center justify-between gap-6">
      <div>
        <p class="eyebrow text-teal">Visítanos</p>
        <h2 class="display-lg mt-2 text-2xl md:text-3xl">Conoce nuestras oficinas</h2>
        <p class="mt-2 text-ink/75">San Cayetano, Cúcuta. Te esperamos.</p>
      </div>
      <a href="https://maps.app.goo.gl/jhAWKJDp7szhNFQs7" target="_blank" rel="noopener" class="btn-primary" data-event="maps-click">
        Ver en Google Maps
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-16 md:py-24" id="faq">
    <div class="container-site max-w-3xl">
      <p class="eyebrow text-teal">Preguntas frecuentes</p>
      <h2 class="display-lg mt-3 text-3xl md:text-4xl">Lo que todos preguntan antes de decidir</h2>
      <div class="mt-8">
        <FaqAccordion items={faq} />
      </div>
    </div>
  </section>

  <!-- CIERRE + FORM -->
  <section class="bg-plum-dark py-16 text-white md:py-24">
    <div class="container-site grid gap-12 md:grid-cols-[6fr_6fr] md:items-center">
      <div>
        <h2 class="display-xl text-3xl md:text-5xl">Da el primer paso</h2>
        <p class="mt-4 max-w-prose leading-relaxed text-white/80">
          Agenda tu visita y conoce el sector acompañado de nuestro equipo. Si estás lejos,
          resolvemos todo por teléfono o videollamada.
        </p>
      </div>

      <form id="form-milote" class="w-full max-w-md rounded-2xl border border-white/15 bg-black/45 p-6 backdrop-blur-md md:justify-self-end md:p-7" data-event="form-submit">
        <p class="eyebrow text-gold">Te contactamos hoy</p>
        <div class="mt-4 space-y-3">
          <input name="nombre" required autocomplete="name" placeholder="Tu nombre" class="w-full rounded-xl border border-white/25 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:border-gold focus:outline-none" />
          <select name="pais" class="w-full rounded-xl border border-white/25 bg-plum-dark px-3 py-2.5 text-sm text-white focus:border-gold focus:outline-none" aria-label="País donde vives">
            <option>Vivo en Colombia</option>
            <option>Vivo en Estados Unidos</option>
            <option>Vivo en España</option>
            <option>Vivo en otro país</option>
          </select>
          <input name="celular" type="tel" required autocomplete="tel" placeholder="Celular (con indicativo)" class="w-full rounded-xl border border-white/25 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:border-gold focus:outline-none" />
        </div>
        <button type="submit" class="btn-primary mt-5 w-full">Agendar visita o llamada</button>
        <p class="mt-3 text-center text-xs text-white/50">Te respondemos por WhatsApp, sin compromiso.</p>
      </form>
    </div>
  </section>
</Base>

<script>
  function setupVideo(videoId: string, btnId: string) {
    const v = document.getElementById(videoId) as HTMLVideoElement | null;
    const btn = document.getElementById(btnId);
    if (!v) return;
    new IntersectionObserver(
      ([e]) => (e.isIntersecting ? v.play().catch(() => {}) : v.pause()),
      { threshold: 0.4 },
    ).observe(v);
    btn?.addEventListener('click', () => {
      v.muted = !v.muted;
      btn.setAttribute('aria-label', v.muted ? 'Activar sonido' : 'Silenciar');
    });
  }

  setupVideo('video-testimonio', 'video-audio-toggle');
  setupVideo('video-recorrido', 'recorrido-audio-toggle');

  const form = document.getElementById('form-milote') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const msg =
      `Hola, vengo de la web de Mi Lote y quiero agendar una visita o llamada.\n` +
      `Nombre: ${data.get('nombre')}\n${data.get('pais')}\nCelular: ${data.get('celular')}`;
    window.open(`https://wa.me/573112382253?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
