  <!-- CIERRE + FORM -->
  <section class="bg-plum-dark py-16 text-white md:py-24">
    <div class="container-site grid gap-12 md:grid-cols-[6fr_6fr] md:items-center">
      <div>
        <h2 class="display-xl text-3xl md:text-5xl">Da el primer paso</h2>
        <p class="mt-4 max-w-prose leading-relaxed text-white/80">
          Agenda tu visita y conoce el sector acompañado de nuestro equipo. Si estás lejos,
          resolvemos todo por teléfono o videollamada.
        </p>
      </div>

      <form id="form-milote" class="w-full max-w-md rounded-2xl border border-white/15 bg-black/45 p-6 backdrop-blur-md md:justify-self-end md:p-7" data-event="form-submit">
        <p class="eyebrow text-gold">Te contactamos hoy</p>
        <div class="mt-4 space-y-3">
          <input name="nombre" required autocomplete="name" placeholder="Tu nombre" class="w-full rounded-xl border border-white/25 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:border-gold focus:outline-none" />
          <select name="pais" class="w-full rounded-xl border border-white/25 bg-plum-dark px-3 py-2.5 text-sm text-white focus:border-gold focus:outline-none" aria-label="País donde vives">
            <option>Vivo en Colombia</option>
            <option>Vivo en Estados Unidos</option>
            <option>Vivo en España</option>
            <option>Vivo en otro país</option>
          </select>
          <input name="celular" type="tel" required autocomplete="tel" placeholder="Celular (con indicativo)" class="w-full rounded-xl border border-white/25 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:border-gold focus:outline-none" />
        </div>
        <button type="submit" class="btn-primary mt-5 w-full">Agendar visita o llamada</button>
        <p class="mt-3 text-center text-xs text-white/50">Te respondemos por WhatsApp, sin compromiso.</p>
      </form>
    </div>
  </section>
</Base>

<script>
  function setupVideo(videoId: string, btnId: string) {
    const v = document.getElementById(videoId) as HTMLVideoElement | null;
    const btn = document.getElementById(btnId);
    if (!v) return;
    new IntersectionObserver(
      ([e]) => (e.isIntersecting ? v.play().catch(() => {}) : v.pause()),
      { threshold: 0.4 },
    ).observe(v);
    btn?.addEventListener('click', () => {
      v.muted = !v.muted;
      btn.setAttribute('aria-label', v.muted ? 'Activar sonido' : 'Silenciar');
    });
  }

  setupVideo('video-recorrido', 'recorrido-audio-toggle');

  // Testimonios carousel
  (() => {
    const slides = Array.from(document.querySelectorAll<HTMLVideoElement>('[data-tv-slide]'));
    const total = slides.length;
    let current = 0;
    let muted = true;

    const dotsContainers = [
      document.getElementById('tv-dots-mobile'),
      document.getElementById('tv-dots-desktop'),
    ];

    // Build dots
    const dots: HTMLButtonElement[] = [];
    dotsContainers.forEach((container) => {
      if (!container) return;
      slides.forEach((_, i) => {
        const d = document.createElement('button');
        d.type = 'button';
        d.className = 'h-2 w-2 rounded-full transition-all ' + (i === 0 ? 'bg-teal w-4' : 'bg-ink/30');
        d.setAttribute('aria-label', `Video ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        container.appendChild(d);
        dots.push(d);
      });
    });

    function updateDots() {
      // Each container has `total` dots; sync both sets
      const allDots = dotsContainers.flatMap((c) => c ? Array.from(c.querySelectorAll('button')) : []);
      allDots.forEach((d, idx) => {
        const pos = idx % total;
        d.className = 'h-2 rounded-full transition-all ' + (pos === current ? 'bg-teal w-4' : 'bg-ink/30 w-2');
      });
    }

    function goTo(index: number) {
      const prev = slides[current];
      prev.pause();
      prev.classList.add('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
      prev.classList.remove('relative');

      current = (index + total) % total;
      const next = slides[current];
      next.muted = muted;
      if (next.getAttribute('preload') === 'none') next.setAttribute('preload', 'auto');
      next.classList.remove('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
      next.play().catch(() => {});
      updateDots();
    }

    // Auto-advance when video ends
    slides.forEach((v, i) => {
      v.addEventListener('ended', () => goTo(i + 1));
    });

    document.getElementById('tv-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('tv-next')?.addEventListener('click', () => goTo(current + 1));

    // Audio toggle
    const iconMuted = document.getElementById('tv-icon-muted');
    const iconSound = document.getElementById('tv-icon-sound');
    document.getElementById('tv-audio')?.addEventListener('click', () => {
      muted = !muted;
      slides[current].muted = muted;
      iconMuted?.classList.toggle('hidden', !muted);
      iconSound?.classList.toggle('hidden', muted);
      document.getElementById('tv-audio')?.setAttribute('aria-label', muted ? 'Activar sonido' : 'Silenciar');
    });

    // Fullscreen
    const carousel = document.getElementById('tv-carousel');
    document.getElementById('tv-fullscreen')?.addEventListener('click', () => {
      const vid = slides[current];
      if (vid.requestFullscreen) vid.requestFullscreen();
      else if ((vid as any).webkitEnterFullscreen) (vid as any).webkitEnterFullscreen();
    });

    // Autoplay on scroll into view
    new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting) slides[current].play().catch(() => {});
        else slides[current].pause();
      },
      { threshold: 0.4 },
    ).observe(carousel!);

    updateDots();
  })();

  const form = document.getElementById('form-milote') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const msg =
      `Hola, vengo de la web de Mi Lote y quiero agendar una visita o llamada.\n` +
      `Nombre: ${data.get('nombre')}\n${data.get('pais')}\nCelular: ${data.get('celular')}`;
    window.open(`https://wa.me/573112382253?text=${encodeURIComponent(msg)}`, '_blank');
  });

  // Lightbox compartido (galería + fotos de testimonios)
  (() => {
    const lb = document.getElementById('tf-lightbox') as HTMLElement | null;
    const lbImg = document.getElementById('tf-lb-img') as HTMLImageElement | null;
    const lbCounter = document.getElementById('tf-lb-counter') as HTMLElement | null;
    if (!lb || !lbImg || !lbCounter) return;

    let srcs: string[] = [];
    let current = 0;

    function show(index: number) {
      current = (index + srcs.length) % srcs.length;
      lbImg!.src = srcs[current];
      lbImg!.alt = `Imagen ${current + 1}`;
      lbCounter!.textContent = srcs.length > 1 ? `${current + 1} / ${srcs.length}` : '';
    }

    function open(newSrcs: string[], index: number) {
      srcs = newSrcs;
      show(index);
      lb!.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lb!.style.display = 'none';
      document.body.style.overflow = '';
    }

    // Galería de la urbanización
    const galleryDataEl = document.getElementById('gallery-photos-data') as HTMLElement | null;
    const gallerySrcs: string[] = galleryDataEl ? JSON.parse(galleryDataEl.dataset.photos || '[]') : [];
    document.querySelectorAll<HTMLButtonElement>('[data-gallery-open]').forEach((btn) => {
      btn.addEventListener('click', () => open(gallerySrcs, Number(btn.dataset.galleryOpen)));
    });

    // Fotos de testimonios
    const tfDataEl = document.getElementById('tf-photos-data') as HTMLElement | null;
    const tfSrcs: string[] = tfDataEl ? JSON.parse(tfDataEl.dataset.photos || '[]') : [];
    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]').forEach((btn) => {
      btn.addEventListener('click', () => open(tfSrcs, Number(btn.dataset.lightboxOpen)));
    });

    // Imágenes individuales (ej: mapa de ubicación)
    document.querySelectorAll<HTMLButtonElement>('[data-lb-single]').forEach((btn) => {
      btn.addEventListener('click', () => open([btn.dataset.lbSingle!], 0));
    });

    document.getElementById('tf-lb-close')?.addEventListener('click', close);
    document.getElementById('tf-lb-prev')?.addEventListener('click', () => show(current - 1));
    document.getElementById('tf-lb-next')?.addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    document.addEventListener('keydown', (e) => {
      if (lb!.style.display === 'none') return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
