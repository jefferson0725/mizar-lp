---
import { getImage, Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import HeroForm from '../components/islands/HeroForm.jsx';
import ProyectoSelector from '../components/islands/ProyectoSelector.jsx';
import VideoCarousel from '../components/islands/VideoCarousel.jsx';
import { getProyectoHref, proyectos } from '../data/proyectos';
import equipoImg from '../assets/equipo.jpg';

const imagenes = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/proyectos/*.png',
  { eager: true },
);

async function resolveImg(nombre: string | null, width = 800) {
  if (!nombre) return null;
  const mod = imagenes[`../assets/proyectos/${nombre}`];
  if (!mod) return null;
  const img = await getImage({ src: mod.default, width, format: 'webp' });
  return img.src;
}

const items = await Promise.all(
  proyectos.map(async (p) => ({
    slug: p.slug,
    nombre: p.nombre,
    tipo: p.tipo,
    ubicacion: p.ubicacion,
    estado: p.estado,
    propositos: p.propositos,
    resumen: p.resumen,
    imgSrc: await resolveImg(p.imagen),
    href: getProyectoHref(p),
  })),
);

// Slideshow del hero (estilo web actual: fade automático cada 5 s)
// TODO: sumar fotos reales de Drive (personas, obras) cuando lleguen
const heroSlides = (
  await Promise.all([
    { src: await resolveImg('piedecuesta.png', 1600), alt: 'Render de apartamentos Terrazas de la Cantera en Piedecuesta' },
    { src: await resolveImg('giron.png', 1600), alt: 'Render de apartamentos Laureles Campestre en Girón' },
    { src: await resolveImg('lotes-cucuta.png', 1600), alt: 'Render aéreo de lotes urbanos Mi Lote en San Cayetano, Cúcuta' },
  ])
).filter((slide): slide is { src: string; alt: string } => Boolean(slide.src));

const equipoSrc = (await getImage({ src: equipoImg, width: 1200, format: 'webp' })).src;
const gironSrc = await resolveImg('giron.png', 1200);
const lotesSrc = await resolveImg('lotes-cucuta.png', 1200);

// Carrusel de videos: 1 video real de testimonios; el resto marcado para
// reemplazar por los videos de Drive (personas, grupos, proyectos)
const carouselSlides = [
  {
    type: 'video',
    src: '/videos/testimonios.mp4',
    label: 'Testimonios',
    quote: 'Historias reales de quienes ya pagan su propiedad directo con la constructora.',
  },
  {
    type: 'image',
    src: equipoSrc,
    label: 'Nuestro equipo',
    quote: 'Una empresa familiar que responde con nombre propio por lo que construye.',
    autor: 'Grupo Mizar · Bucaramanga',
  },
  {
    type: 'image',
    src: gironSrc,
    label: 'Proyectos',
    quote: 'Llevaba años pagando arriendo y pensando que sin crédito nunca iba a tener nada. Hoy pago la cuota de mi apartamento directo con la constructora.',
    autor: 'Propietaria en Girón',
  },
  {
    type: 'image',
    src: lotesSrc,
    label: 'Inversionistas',
    quote: 'Compré mi lote desde Estados Unidos. Todo el proceso fue por videollamada y los documentos llegaron en regla.',
    autor: 'Inversionista en Cúcuta, vive en EE. UU.',
  },
];
---

<Base
  title="Grupo Mizar — Propiedades a cuotas y sin bancos en Colombia"
  description="Apartamentos, parcelas y lotes urbanos en Santander y Norte de Santander. +20 años construyendo en Colombia y +100 proyectos entregados, a cuotas y sin bancos."
  path="/"
  headerTransparent
>
  <!-- HERO: video de fondo, header flotante encima, contenido anclado abajo -->
  <section class="relative flex min-h-[80svh] flex-col justify-end overflow-hidden bg-neutral-950 text-white md:min-h-[90vh] md:justify-center">
    <div id="hero-slides" class="absolute inset-0" aria-hidden="true">
      {
        heroSlides.map((slide, i) => (
          <img
            src={slide.src}
            alt={slide.alt}
            class="absolute inset-0 h-full w-full object-cover transition-opacity duration-500"
            style={`opacity:${i === 0 ? 1 : 0};`}
            data-hero-slide
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : 'auto'}
          />
        ))
      }
      <video
        class="absolute inset-0 h-full w-full object-cover motion-reduce:hidden"
        muted
        loop
        playsinline
        preload="none"
        poster={heroSlides[0]?.src}
        data-hero-video
        data-src="/videos/hero-mizar.mp4"
        aria-hidden="true"
      ></video>
      <div class="absolute inset-0" style="background:#00000080;"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/30"></div>
    </div>

    <div class="container-site relative grid gap-10 py-14 md:grid-cols-[7fr_5fr] md:items-center md:gap-14 md:py-20">
      <div>
        <p class="eyebrow hidden text-gold md:block">Constructora · +20 años en Colombia</p>
        <h1 class="display-xl mt-10 text-4xl md:mt-4 md:text-6xl">
          Convertimos tu esfuerzo en propiedades, a cuotas y sin bancos
        </h1>

        <dl class="mt-6 grid grid-cols-3 gap-x-4 md:mt-9 md:flex md:flex-nowrap md:gap-x-6 md:gap-y-6 lg:gap-x-10">
          <div class="md:shrink-0">
            <dt class="sr-only">Años construyendo en Colombia</dt>
            <dd class="stat-num text-3xl text-white md:text-4xl lg:text-5xl">20<span class="text-mizar">+</span></dd>
            <dd class="mt-1 text-[10px] font-semibold tracking-wider text-white/70 uppercase md:text-xs">Años construyendo en Colombia</dd>
          </div>
          <div class="md:shrink-0">
            <dt class="sr-only">Proyectos entregados</dt>
            <dd class="stat-num text-3xl text-white md:text-4xl lg:text-5xl">100<span class="text-mizar">+</span></dd>
            <dd class="mt-1 text-[10px] font-semibold tracking-wider text-white/70 uppercase md:text-xs">Proyectos entregados</dd>
          </div>
          <div class="md:shrink-0">
            <dt class="sr-only">Dónde construimos</dt>
            <dd class="stat-num text-3xl text-white md:text-4xl lg:text-5xl">2</dd>
            <dd class="mt-1 text-[10px] font-semibold tracking-wider text-white/70 uppercase md:text-xs">Santander y N. de Santander</dd>
          </div>
        </dl>
      </div>

      <div class="md:justify-self-end">
        <HeroForm client:idle />
      </div>
    </div>
  </section>

  <!-- CARRUSEL DE VIDEOS (personas, grupos, proyectos — auto) -->
  <section class="bg-white py-16 md:py-24">
    <div class="container-site">
      <div class="mb-8 max-w-2xl">
        <p class="eyebrow text-teal">Historias reales</p>
        <h2 class="display-lg mt-3 text-3xl md:text-4xl">Ya lo están logrando</h2>
      </div>
      <VideoCarousel slides={carouselSlides} client:visible />
    </div>
  </section>

  <!-- FOTO DEL EQUIPO -->
  <section class="relative overflow-hidden bg-plum text-white">
    <div class="container-site grid items-center gap-10 py-16 md:grid-cols-[5fr_7fr] md:py-24">
      <div>
        <p class="eyebrow text-gold">Empresa familiar</p>
        <h2 class="display-lg mt-3 text-3xl md:text-4xl">
          Tu libertad empieza con una decisión segura.
        </h2>
        <p class="mt-5 max-w-md leading-relaxed text-white/75">
          Detrás de cada obra hay un equipo que responde con nombre propio por lo que
          construye. Somos ingenieros santandereanos y llevamos más de veinte años
          entregando lo que prometemos.
        </p>
        <a href="/nosotros" class="btn-outline mt-8 text-white">Conócenos</a>
      </div>
      <Image
        src={equipoImg}
        alt="Equipo de Grupo Mizar frente a sus oficinas en Bucaramanga"
        widths={[480, 800, 1100]}
        sizes="(min-width: 768px) 55vw, 100vw"
        format="webp"
        loading="lazy"
        class="h-full w-full rounded-[4px] object-cover"
      />
    </div>
  </section>

  <!-- PROYECTOS: selector + miniaturas -->
  <section class="py-16 md:py-24" id="proyectos">
    <div class="container-site">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-2xl">
          <p class="eyebrow text-teal">Portafolio</p>
          <h2 class="display-lg mt-3 text-3xl md:text-4xl">Encuentra tu proyecto</h2>
          <p class="mt-4 text-ink/70">
            Apartamentos sobre planos, parcelas campestres y lotes urbanos. Filtra por lo
            que buscas y para qué lo buscas.
          </p>
        </div>
        <a href="/proyectos" class="btn-primary">Conoce nuestros proyectos</a>
      </div>
      <ProyectoSelector items={items} singleRow client:visible />
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-plum-dark py-16 text-white md:py-20">
    <div class="container-site flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="display-lg text-3xl md:text-4xl">Da el primer paso</h2>
        <p class="mt-3 max-w-lg text-white/70">
          Agenda una visita o una llamada. Si estás fuera del país, resolvemos todo por
          teléfono o videollamada.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="https://wa.me/573112382253?text=Hola,%20vengo%20de%20la%20web%20de%20Grupo%20Mizar%20y%20quiero%20agendar%20una%20visita."
          target="_blank"
          rel="noopener"
          class="btn-primary"
          data-event="whatsapp-click"
        >
          Escríbenos por WhatsApp
        </a>
        <a href="/contacto" class="btn-outline text-white">Ir a contacto</a>
      </div>
    </div>
  </section>
</Base>

<script>
  // Hero video loads after the browser has time to paint the poster/LCP image.
  const slides = Array.from(
    document.querySelectorAll<HTMLImageElement>('[data-hero-slide]'),
  );
  const video = document.querySelector<HTMLVideoElement>('[data-hero-video]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const requestIdle =
    window.requestIdleCallback ??
    ((callback: IdleRequestCallback) =>
      window.setTimeout(
        () => callback({ didTimeout: false, timeRemaining: () => 0 } as IdleDeadline),
        1200,
      ));

  function startSlideshow() {
    if (slides.length > 1 && !reduced) {
      let i = 0;
      setInterval(() => {
        slides[i].style.opacity = '0';
        i = (i + 1) % slides.length;
        slides[i].style.opacity = '1';
      }, 5000);
    }
  }

  function loadHeroVideo() {
    if (!video?.dataset.src) return;
    video.src = video.dataset.src;
    video.load();
    video.play().catch(() => {
      startSlideshow();
    });
  }

  if (!video || reduced) {
    startSlideshow();
  } else {
    video.addEventListener('error', () => {
      video.remove();
      startSlideshow();
    });
    requestIdle(loadHeroVideo, { timeout: 2500 });
  }
</script>
