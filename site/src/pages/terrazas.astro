---
import LandingReact from "../layouts/LandingReact.astro";
import Header from "../components/Header.astro";
import IntroParallax from "../landing/terrazas/IntroParallax.astro";
import Testimonios from "../landing/terrazas/Testimonios.astro";
import Comentarios from "../landing/terrazas/Comentarios.astro";
import Ubicacion from "../landing/terrazas/Ubicacion.astro";
import Apartamentos from "../landing/terrazas/components/Apartamentos.jsx";
import QuienesSomos from "../landing/terrazas/QuienesSomos.astro";
import Precios from "../landing/terrazas/Precios.astro";
import FAQ from "../landing/terrazas/FAQ.astro";
import Resumen from "../landing/terrazas/Resumen.astro";
import Contacto from "../landing/terrazas/Contacto.astro";
import TerrazasFooter from "../landing/terrazas/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
---

<LandingReact
  title="Terrazas de la Cantera · Apartamentos en Piedecuesta | Mizar"
  description="Apartamentos propios en Piedecuesta con vista al Cerro de La Cantera. Sin bancos y a cuotas, directo con Mizar. 60 m², 3 alcobas. Entrega diciembre 2027."
  ogImage="/assets/terrazas-fachada.webp"
  path="/terrazas"
  headerColor="#025362"
  headerColorDark="#013a45"
>
  <Header transparent />
  <!-- .theme-terrazas sobreescribe los tokens CSS (navy → teal, rojo → lima) -->
  <div class="theme-terrazas">
    <IntroParallax />
    <Testimonios />
    <Comentarios />
    <Ubicacion />
    <Apartamentos client:visible />
    <QuienesSomos />
    <Precios />
    <FAQ />
    <Resumen />
    <Contacto />
    <TerrazasFooter />
    <WhatsAppFloat
      phone="573112658552"
      message="Me interesan los apartamentos de Terrazas de la Cantera, mi nombre es"
    />
  </div>
</LandingReact>

<script>
  // Reveal on scroll — activa .in-view en elementos .reveal al entrar al viewport.
  // Respeta prefers-reduced-motion.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  } else {
    // Si prefiere reduced-motion, mostrar todo inmediatamente
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
  }
</script>
