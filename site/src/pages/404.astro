---
import Base from '../layouts/Base.astro';

const API_URL = import.meta.env.BLOG_API_URL ?? 'https://api.grupomizar.com.co';
---

<Base
  title="Página no encontrada | Grupo Mizar"
  description="La página que buscas no existe. Explora nuestros proyectos inmobiliarios en Colombia: apartamentos, parcelas y lotes a cuotas sin bancos."
  path="/404"
>
  <!-- 404 por defecto, se oculta si la URL es un post de blog válido -->
  <section id="not-found" class="flex min-h-[70vh] flex-col items-center justify-center bg-cream px-6 text-center">
    <p class="text-8xl font-black text-plum/10">404</p>
    <h1 class="mt-4 text-3xl font-bold text-ink md:text-4xl">Esta página no existe</h1>
    <p class="mt-4 max-w-prose text-ink/70">
      Puede que el enlace esté desactualizado o que la dirección tenga un error.
      Puedes volver al inicio o ir directamente a contactarnos.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Ir al inicio</a>
      <a href="/contacto" class="btn-outline">Contacto</a>
    </div>
  </section>

  <!-- Contenedor del artículo (oculto hasta confirmar que el post existe) -->
  <article id="blog-post" style="display:none" class="bg-cream">
    <header class="bg-plum-dark py-16 text-white md:py-24">
      <div class="container-site max-w-prose">
        <p id="bp-frente" class="eyebrow text-gold"></p>
        <h1 id="bp-title" class="display-xl mt-4 text-4xl md:text-6xl"></h1>
        <p id="bp-description" class="mt-6 text-lg text-white/80"></p>
        <p id="bp-meta" class="mt-6 text-sm font-semibold text-white/65"></p>
      </div>
    </header>
    <div class="container-site max-w-prose py-12 md:py-16">
      <div id="bp-content" class="article-body"></div>
    </div>
  </article>
</Base>

<style>
  .article-body {
    color: var(--color-ink);
    font-size: 1.075rem;
    line-height: 1.8;
  }
  .article-body :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-plum);
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-variation-settings: "wdth" 112;
    font-weight: 800;
    line-height: 1.12;
  }
  .article-body :global(p) { margin-top: 1rem; }
  .article-body :global(ul) { margin-top: 1rem; padding-left: 1.25rem; list-style: square; }
  .article-body :global(li) { margin-top: 0.5rem; }
  .article-body :global(strong) { color: var(--color-plum); font-weight: 800; }
</style>

<script define:vars={{ API_URL }}>
  (async () => {
    const match = window.location.pathname.match(/^\/blog\/([^/]+)\/?$/);
    if (!match) return; // no es una URL de blog, mostrar 404 normal

    const slug = match[1];
    try {
      const res = await fetch(`${API_URL}/api/posts/${slug}`);
      if (!res.ok) return; // post no existe o es borrador, mostrar 404

      const post = await res.json();
      document.title = `${post.title} | Grupo Mizar`;

      const { marked } = await import('https://esm.sh/marked@18');

      document.getElementById('bp-frente').textContent = post.frente.replace(/-/g, ' ');
      document.getElementById('bp-title').textContent = post.title;
      document.getElementById('bp-description').textContent = post.description;

      const date = new Intl.DateTimeFormat('es-CO', {
        year: 'numeric', month: 'long', day: 'numeric',
      }).format(new Date(post.pub_date));
      document.getElementById('bp-meta').textContent = `${date} · ${post.author}`;
      document.getElementById('bp-content').innerHTML = marked.parse(post.content);

      document.getElementById('not-found').style.display = 'none';
      document.getElementById('blog-post').style.display = '';
    } catch {
      // dejar el 404 visible
    }
  })();
</script>
