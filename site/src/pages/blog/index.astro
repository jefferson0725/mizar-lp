---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('es-CO', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
---

<Base
  title="Blog inmobiliario | Grupo Mizar"
  description="Guías de Grupo Mizar sobre propiedades a cuotas, inversión desde el exterior y compra directa con constructora en Colombia."
  path="/blog"
>
  <section class="bg-plum-dark py-16 text-white md:py-24">
    <div class="container-site">
      <p class="eyebrow text-gold">Blog Mizar</p>
      <h1 class="display-xl mt-4 max-w-4xl text-4xl md:text-6xl">
        Respuestas claras para comprar propiedad en Colombia, a cuotas y sin bancos
      </h1>
      <p class="mt-6 max-w-prose text-lg text-white/80">
        Contenido práctico para trabajadores colombianos, familias en Santander y Norte de Santander, y colombianos en el exterior que quieren invertir con respaldo local.
      </p>
    </div>
  </section>

  <section class="bg-cream py-16 md:py-24">
    <div class="container-site">
      <div class="grid gap-6 md:grid-cols-3">
        {
          posts.map((post) => (
            <article class="rounded-2xl border border-ink/10 bg-white p-6">
              <p class="eyebrow text-teal">{post.data.frente.replace('-', ' ')}</p>
              <h2 class="display-lg mt-4 text-2xl">
                <a class="hover:text-mizar" href={`/blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-3 text-sm font-semibold text-ink/60">{formatDate(post.data.pubDate)}</p>
              <p class="mt-4 text-ink/75">{post.data.description}</p>
              <div class="mt-6 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full bg-cream px-3 py-1 text-sm font-semibold text-plum">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>
