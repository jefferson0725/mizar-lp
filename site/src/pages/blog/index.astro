---
import Base from '../../layouts/Base.astro';

const API_URL = import.meta.env.BLOG_API_URL ?? 'https://api.grupomizar.com.co';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://grupomizar.com.co/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://grupomizar.com.co/blog' },
  ],
};
---

<Base
  title="Blog inmobiliario | Grupo Mizar"
  description="Guías de Grupo Mizar para comprar propiedad en Colombia a cuotas y sin bancos: apartamentos VIS, inversión desde el exterior y respaldo de constructora."
  path="/blog"
  schema={schema}
>
  <section class="bg-plum-dark py-16 text-white md:py-24">
    <div class="container-site">
      <p class="eyebrow text-gold">Blog Mizar</p>
      <h1 class="display-xl mt-4 max-w-4xl text-4xl md:text-6xl">
        Respuestas claras para comprar propiedad en Colombia, a cuotas y sin bancos
      </h1>
      <p class="mt-6 max-w-prose text-lg text-white/80">
        Contenido práctico para trabajadores colombianos, familias en Santander y Norte de Santander, y colombianos en el exterior que quieren invertir con respaldo local.
      </p>
    </div>
  </section>

  <section class="bg-cream py-16 md:py-24">
    <div class="container-site">
      <div id="posts-grid" class="grid gap-6 md:grid-cols-3">
        <p class="col-span-3 text-ink/50">Cargando artículos...</p>
      </div>
    </div>
  </section>
</Base>

<script define:vars={{ API_URL }}>
  function esc(s) {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
  function fmtDate(d) {
    return new Intl.DateTimeFormat('es-CO', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));
  }

  (async () => {
    const grid = document.getElementById('posts-grid');
    try {
      const res = await fetch(`${API_URL}/api/posts`);
      if (!res.ok) throw new Error();
      const posts = await res.json();

      if (posts.length === 0) {
        grid.innerHTML = '<p class="col-span-3 text-ink/50">Próximamente nuevos artículos.</p>';
        return;
      }

      grid.innerHTML = posts.map(p => `
        <article class="rounded-2xl border border-ink/10 bg-white p-6">
          <p class="eyebrow text-teal">${esc(p.frente.replace(/-/g, ' '))}</p>
          <h2 class="display-lg mt-4 text-2xl">
            <a class="hover:text-mizar" href="/blog/${esc(p.slug)}/">${esc(p.title)}</a>
          </h2>
          <p class="mt-3 text-sm font-semibold text-ink/60">${fmtDate(p.pub_date)}</p>
          <p class="mt-4 text-ink/75">${esc(p.description)}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            ${(p.tags ?? []).map(t => `<span class="rounded-full bg-cream px-3 py-1 text-sm font-semibold text-plum">${esc(t)}</span>`).join('')}
          </div>
        </article>
      `).join('');
    } catch {
      grid.innerHTML = '<p class="col-span-3 text-ink/50">No se pudieron cargar los artículos.</p>';
    }
  })();
</script>
