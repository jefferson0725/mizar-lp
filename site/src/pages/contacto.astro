---
import Base from '../layouts/Base.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto — Grupo Mizar',
  mainEntity: {
    '@type': 'RealEstateAgent',
    name: 'Grupo Mizar',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Calle 105A #23a-18, Provenza',
      addressLocality: 'Bucaramanga',
      addressRegion: 'Santander',
      addressCountry: 'CO',
    },
  },
};
---

<Base
  title="Contacto | Grupo Mizar — Bucaramanga"
  description="Contacta a Grupo Mizar en Bucaramanga: formulario, WhatsApp y oficinas en Provenza. Te atendemos si buscas propiedad en Colombia o desde el exterior también."
  path="/contacto"
  schema={schema}
>
  <section class="py-16 md:py-24">
    <div class="container-site grid gap-12 md:grid-cols-[6fr_6fr]">
      <div>
        <p class="eyebrow text-teal">Contacto</p>
        <h1 class="display-xl mt-4 text-4xl md:text-5xl">Hablemos de tu próxima propiedad</h1>
        <p class="mt-5 max-w-prose leading-relaxed text-ink/75">
          Cuéntanos qué buscas y te respondemos por WhatsApp. Si vives fuera de Colombia,
          coordinamos una videollamada en tu horario.
        </p>

        <form id="form-contacto" class="mt-8 max-w-md space-y-4" data-event="form-submit">
          <div>
            <label for="nombre" class="mb-1.5 block text-sm font-bold">Tu nombre</label>
            <input
              id="nombre"
              name="nombre"
              required
              autocomplete="name"
              class="w-full rounded-xl border border-ink/20 bg-white px-3.5 py-2.5 focus:border-teal focus:outline-none"
            />
          </div>
          <div>
            <label for="pais" class="mb-1.5 block text-sm font-bold">País donde vives</label>
            <select
              id="pais"
              name="pais"
              class="w-full rounded-xl border border-ink/20 bg-white px-3.5 py-2.5 focus:border-teal focus:outline-none"
            >
              <option>Colombia</option>
              <option>Estados Unidos</option>
              <option>España</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label for="interes" class="mb-1.5 block text-sm font-bold">Qué te interesa</label>
            <select
              id="interes"
              name="interes"
              class="w-full rounded-xl border border-ink/20 bg-white px-3.5 py-2.5 focus:border-teal focus:outline-none"
            >
              <option>Apartamento</option>
              <option>Parcela campestre</option>
              <option>Lote urbano en Cúcuta</option>
              <option>Aún no lo sé</option>
            </select>
          </div>
          <div>
            <label for="celular" class="mb-1.5 block text-sm font-bold">Celular (con indicativo)</label>
            <input
              id="celular"
              name="celular"
              type="tel"
              required
              autocomplete="tel"
              placeholder="+57 300 000 0000"
              class="w-full rounded-xl border border-ink/20 bg-white px-3.5 py-2.5 focus:border-teal focus:outline-none"
            />
          </div>
          <button type="submit" class="btn-primary w-full">Enviar por WhatsApp</button>
          <p class="text-xs text-ink/50">Al enviar se abre WhatsApp con tu mensaje listo. Sin spam, sin compromiso.</p>
        </form>
      </div>

      <div class="space-y-8">
        <div class="border border-ink/10 bg-white p-6 md:p-8">
          <h2 class="font-bold">Nuestras oficinas</h2>
          <p class="mt-2 text-ink/75">
            Calle 105A #23a-18, Provenza<br />
            Bucaramanga, Santander
          </p>
          <a
            href="https://maps.app.goo.gl/cjd7zaDX9qxuy5KW6"
            target="_blank"
            rel="noopener"
            class="mt-3 inline-block font-bold text-mizar hover:underline"
          >
            Ver en Google Maps →
          </a>
          <iframe
            src="https://www.google.com/maps?q=Calle+105A+%2323a-18,+Provenza,+Bucaramanga&output=embed"
            title="Mapa de las oficinas de Grupo Mizar en Provenza, Bucaramanga"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="mt-5 h-64 w-full rounded-2xl border-0"
            allowfullscreen
          ></iframe>
        </div>

        <div class="border border-ink/10 bg-plum p-6 text-white md:p-8">
          <h2 class="font-bold">¿Prefieres escribir directo?</h2>
          <p class="mt-2 text-white/75">Te respondemos en horario laboral de Colombia (GMT-5).</p>
          <a
            href="https://wa.me/573112382253?text=Hola,%20vengo%20de%20la%20web%20de%20Grupo%20Mizar."
            target="_blank"
            rel="noopener"
            class="btn-primary mt-4"
            data-event="whatsapp-click"
          >
            Abrir WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('form-contacto') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const msg =
      `Hola, vengo de la web de Grupo Mizar.\n` +
      `Nombre: ${data.get('nombre')}\n` +
      `Vivo en: ${data.get('pais')}\n` +
      `Me interesa: ${data.get('interes')}\n` +
      `Celular: ${data.get('celular')}`;
    window.open(`https://wa.me/573112382253?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
