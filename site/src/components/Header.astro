---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/blog', label: 'Blog' },
];
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  class="fixed inset-x-0 top-0 z-50 bg-transparent text-white transition-colors duration-300"
  data-header
  data-transparent={transparent}
>
  <div class="container-site flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center" aria-label="Grupo Mizar — Inicio">
      <img src="/logo-mizar.webp" alt="Mizar Diseño y Construcción" width="150" height="44" class="h-10 w-auto" />
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Principal">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'text-sm font-semibold transition-colors hover:text-gold',
              isActive(l.href) ? 'text-gold' : 'text-white',
            ]}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contacto" class="btn-primary !py-2 !px-5 text-sm">Contáctanos</a>
    </nav>

    <button
      id="menu-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-lg md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-white/10 bg-plum-dark md:hidden" aria-label="Menú móvil">
    <div class="container-site flex flex-col gap-1 py-3">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'rounded-lg px-3 py-3 text-base font-semibold',
              isActive(l.href) ? 'text-gold' : 'text-white',
            ]}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contacto" class="btn-primary mt-2 justify-center">Contáctanos</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.querySelector<HTMLElement>('[data-header]');
  const isTransparent = header?.dataset.transparent === 'true';
  let menuOpen = false;
  let hovered = false;

  function syncHeaderBg() {
    if (!header) return;
    const solid = !isTransparent || window.scrollY > 24 || menuOpen || hovered;
    header.classList.toggle('bg-plum', solid);
    header.classList.toggle('shadow-lg', solid);
    header.classList.toggle('bg-transparent', !solid);
  }

  function syncInstant() {
    if (!header) return;
    header.style.transition = 'none';
    syncHeaderBg();
    requestAnimationFrame(() => { header.style.transition = ''; });
  }

  window.addEventListener('scroll', syncHeaderBg, { passive: true });
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') syncInstant();
  });
  header?.addEventListener('mouseenter', () => { hovered = true; syncHeaderBg(); });
  header?.addEventListener('mouseleave', () => { hovered = false; syncHeaderBg(); });

  toggle?.addEventListener('click', () => {
    menuOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(menuOpen));
    syncHeaderBg();
  });

  syncInstant();
</script>
