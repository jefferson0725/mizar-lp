---
interface Props {
  direccion?: string;
}
const { direccion = 'Calle 105A #23a-18, Provenza, Bucaramanga' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-plum-dark text-white">
  <div class="container-site grid gap-10 py-12 md:grid-cols-3">
    <div>
      <img src="/logo-mizar.webp" alt="Grupo Mizar" width="150" height="44" class="h-10 w-auto" />
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-white/70">
        Convertimos tu esfuerzo en propiedades, a cuotas y sin bancos. Más de 20 años
        construyendo en Colombia, más de 100 proyectos entregados.
      </p>
    </div>

    <nav aria-label="Mapa del sitio" class="text-sm">
      <p class="mb-3 font-bold text-gold">Explora</p>
      <ul class="space-y-2 text-white/80">
        <li><a href="/nosotros" class="hover:text-white">Nosotros</a></li>
        <li><a href="/proyectos" class="hover:text-white">Proyectos</a></li>
        <li><a href="/blog" class="hover:text-white">Blog</a></li>
        <li><a href="/contacto" class="hover:text-white">Contacto</a></li>
      </ul>
    </nav>

    <div class="text-sm">
      <p class="mb-3 font-bold text-gold">Contacto</p>
      <ul class="space-y-2 text-white/80">
        <li>
          <a href="https://maps.app.goo.gl/cjd7zaDX9qxuy5KW6" rel="noopener" target="_blank" class="hover:text-white">
            <span class="font-semibold text-white/60">Dirección:</span> {direccion}
          </a>
        </li>
        <li>
          <a href="https://wa.me/573112382253" rel="noopener" target="_blank" class="hover:text-white">
            WhatsApp: +57 311 238 2253
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-xs text-white/50">
    © {year} Grupo Mizar. Todos los derechos reservados.
  </div>
</footer>
