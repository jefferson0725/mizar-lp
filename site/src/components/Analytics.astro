---
// Lee el ID de GA4 en tiempo de build. Vacío si no está configurado.
const ga4Id = import.meta.env.PUBLIC_GA4_ID ?? '';

// Snippet oficial de GA4, solo se inyecta cuando hay ID configurado.
const ga4Snippet = ga4Id
  ? `<script async src="https://www.googletagmanager.com/gtag/js?id=${ga4Id}"></script>` +
    `<script>window.dataLayer=window.dataLayer||[];` +
    `function gtag(){window.dataLayer.push(arguments);}` +
    `gtag('js',new Date());gtag('config','${ga4Id}');</script>`
  : '';
---

{ga4Id && <Fragment set:html={ga4Snippet} />}

<script is:inline>
  window.dataLayer = window.dataLayer || [];

  function _pushEvent(nombre, props) {
    window.dataLayer.push(Object.assign({ event: nombre }, props));
    if (typeof window.gtag === 'function') window.gtag('event', nombre, props);
  }

  // Listener delegado: clicks en cualquier elemento con data-event
  document.addEventListener('click', function (e) {
    var el = e.target ? e.target.closest('[data-event]') : null;
    if (!el) return;
    var props = { page_path: window.location.pathname };
    if (el.tagName === 'A' && el.href) props.link_url = el.href;
    var txt = (el.textContent || '').trim();
    if (txt) props.link_text = txt.slice(0, 100);
    _pushEvent(el.getAttribute('data-event'), props);
  });

  // Listener delegado: envíos de formularios con data-event
  document.addEventListener('submit', function (e) {
    var form = e.target ? e.target.closest('[data-event]') : null;
    if (!form) return;
    _pushEvent(form.getAttribute('data-event'), { page_path: window.location.pathname });
  });
</script>
