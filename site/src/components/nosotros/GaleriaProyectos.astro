---
import { Image } from 'astro:assets';
import GalleryCarousel from '../GalleryCarousel.astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/nosotros/proyectos/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const fotos = Object.entries(modules).map(([path, mod]) => ({
  src: mod.default,
  alt: `Obra construida por Grupo Mizar: ${path.split('/').pop()!.replace(/.[^.]+$/, '').replace(/[-_]/g, ' ')}`,
}));
---

{
  fotos.length > 0 && (
    <section class="pb-16 md:pb-24">
      <div class="container-site">
        <p class="eyebrow text-teal">Así hemos construido</p>
        <div class="relative mt-4" data-carousel-root>
          <div
            data-carousel-track
            class="flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth"
            style="scrollbar-width: none; -ms-overflow-style: none;"
          >
            {fotos.map((foto) => (
              <div class="min-w-[100%] snap-start overflow-hidden rounded-2xl sm:min-w-[90%] lg:min-w-[72%]">
                <Image
                  src={foto.src}
                  alt={foto.alt}
                  widths={[800, 1400, 2000]}
                  sizes="(min-width: 1024px) 72vw, 95vw"
                  format="webp"
                  loading="lazy"
                  class="h-auto w-full"
                  style="aspect-ratio:16/9;object-fit:contain;background:#f0f0f0"
                />
              </div>
            ))}
          </div>
          <GalleryCarousel />
        </div>
        <div data-carousel-dots class="mt-5 flex items-center justify-center gap-2"></div>
      </div>
    </section>
  )
}
