---
// Renders prev/next buttons + dots script. Place inside a `relative` wrapper:
//   <div class="relative mt-8" data-carousel-root>
//     <div data-carousel-track class="flex snap-x ...">…items…</div>
//     <GalleryCarousel />
//   </div>
//   <div data-carousel-dots class="mt-5 flex justify-center gap-2"></div>
---

<button
  data-carousel-prev
  class="absolute left-2 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/95 shadow-lg text-ink backdrop-blur-sm transition-all duration-150 hover:scale-105 active:scale-95 disabled:opacity-30 md:left-3"
  aria-label="Anterior"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <path d="M15 18l-6-6 6-6"/>
  </svg>
</button>
<button
  data-carousel-next
  class="absolute right-2 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/95 shadow-lg text-ink backdrop-blur-sm transition-all duration-150 hover:scale-105 active:scale-95 disabled:opacity-30 md:right-3"
  aria-label="Siguiente"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <path d="M9 18l6-6-6-6"/>
  </svg>
</button>

<style>
  [data-carousel-track]::-webkit-scrollbar { display: none; }
</style>

<script>
  function initCarousel(root) {
    const track = root.querySelector('[data-carousel-track]');
    const prev = root.querySelector('[data-carousel-prev]');
    const next = root.querySelector('[data-carousel-next]');
    const dotsEl = root.nextElementSibling;

    if (!track || !prev || !next || !dotsEl || !dotsEl.matches('[data-carousel-dots]')) return;

    const items = Array.from(track.children);

    items.forEach(function(_, i) {
      var dot = document.createElement('button');
      dot.setAttribute('aria-label', 'Elemento ' + (i + 1));
      dot.addEventListener('click', function() { goTo(i); });
      dotsEl.appendChild(dot);
    });

    function getActive() {
      var trackLeft = track.getBoundingClientRect().left;
      var closest = 0, min = Infinity;
      items.forEach(function(el, i) {
        var d = Math.abs(el.getBoundingClientRect().left - trackLeft);
        if (d < min) { min = d; closest = i; }
      });
      return closest;
    }

    function updateDots(active) {
      dotsEl.querySelectorAll('button').forEach(function(dot, i) {
        dot.className = i === active
          ? 'h-2 w-6 rounded-full transition-all duration-300 bg-teal'
          : 'h-2 w-2 rounded-full transition-all duration-300 bg-ink/25';
      });
      prev.disabled = active === 0;
      next.disabled = active === items.length - 1;
    }

    function goTo(i) {
      var el = items[i];
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    }

    track.addEventListener('scroll', function() { updateDots(getActive()); }, { passive: true });
    prev.addEventListener('click', function() { goTo(Math.max(0, getActive() - 1)); });
    next.addEventListener('click', function() { goTo(Math.min(items.length - 1, getActive() + 1)); });

    updateDots(0);
  }

  document.querySelectorAll('[data-carousel-root]').forEach(initCarousel);
</script>
