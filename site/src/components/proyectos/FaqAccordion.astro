---
interface Props {
  items: { q: string; a: string }[];
  /** true = texto claro sobre fondo oscuro */
  dark?: boolean;
}
const { items, dark = false } = Astro.props;
---

<div class:list={['divide-y', dark ? 'divide-white/10' : 'divide-ink/10']}>
  {
    items.map((item) => (
      <details class="group py-4">
        <summary
          class:list={[
            'flex cursor-pointer list-none items-center justify-between gap-4 font-bold',
            dark ? 'text-white' : 'text-ink',
          ]}
        >
          {item.q}
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            class="shrink-0 transition-transform group-open:rotate-45"
            aria-hidden="true"
          >
            <path d="M12 5v14M5 12h14" />
          </svg>
        </summary>
        <p class:list={['mt-3 max-w-prose leading-relaxed', dark ? 'text-white/75' : 'text-ink/75']}>
          {item.a}
        </p>
      </details>
    ))
  }
</div>
